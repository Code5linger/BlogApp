model User {
    id            String   @id @default(cuid())
    name          String
    email         String   @unique
    emailVerified Boolean  @default(false)
    image         String?
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    role   String  @default("USER")
    phone  String?
    status String  @default("ACTIVE")

    sessions Session[]
    accounts Account[]

    @@map("user")
}
